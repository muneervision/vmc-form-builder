rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // User-owned uploads (branding assets, profile photos):
    // /users/{uid}/**
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024; // 10MB cap
    }

    // Response file uploads (attachments submitted by respondents):
    // /forms/{formId}/responses/{responseId}/**
    match /forms/{formId}/responses/{responseId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.resource.size < 25 * 1024 * 1024; // 25MB cap
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
